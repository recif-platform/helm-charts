# Local dev secrets — copy to values-secret.yaml and fill in your keys.
# values-secret.yaml is gitignored and auto-loaded by `make deploy`.
#
# For production, use External Secrets instead:
#   secrets.provider: "external"
# See docs: Secret Management guide.

llm:
  # Uncomment the providers you use:
  # googleApiKey: "AIza..."
  # openaiApiKey: "sk-..."
  # anthropicApiKey: "sk-ant-..."

  # AWS Bedrock:
  # awsRegion: "us-east-1"
  # awsAccessKeyId: "AKIA..."
  # awsSecretAccessKey: "..."

  # Google Cloud / Vertex AI:
  # gcp:
  #   project: "my-project-123"
  #   location: "us-central1"
  #   serviceAccountKeyBase64: ""  # cat sa-key.json | base64 | tr -d '\n'
